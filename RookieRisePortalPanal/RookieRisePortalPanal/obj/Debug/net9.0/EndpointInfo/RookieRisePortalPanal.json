  "components": {
    "schemas": {
      "CreateCompanyDto": {
        "required": [
          "nameAr",
          "nameEn"
        ],
        "type": "object",
        "properties": {
          "nameEn": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "nameAr": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "websiteUrl": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "logoName": {
            "type": "string",
            "nullable": true
          },
          "logoPath": {
            "type": "string",
            "format": "binary",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SetPasswordDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "token": {
            "type": "string",
            "nullable": true
          },
          "newPassword": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateCompanyDto": {
        "required": [
          "companyId",
          "nameAr",
          "nameEn"
        ],
        "type": "object",
        "properties": {
          "companyId": {
            "type": "string",
            "format": "uuid"
          },
          "nameEn": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "nameAr": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "websiteUrl": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "logoName": {
            "type": "string",
            "nullable": true
          },
          "logoPath": {
            "type": "string",
            "format": "binary",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "type": "integer",
            "format": "int32"
          },
          "temperatureF": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Enter: Bearer {your token}",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
