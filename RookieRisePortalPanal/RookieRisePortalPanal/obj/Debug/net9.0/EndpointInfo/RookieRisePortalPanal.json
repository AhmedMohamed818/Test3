              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SetPasswordDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Account/email-exists": {
      "get": {
        "tags": [
          "Account"
        ],
        "parameters": [
          {
            "name": "email",
