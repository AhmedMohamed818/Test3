        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Account/register": {
      "post": {
        "tags": [
          "Account"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "NameAr",
                  "NameEn"
                ],
                "type": "object",
                "properties": {
                  "NameEn": {
                    "type": "string"
                  },
                  "NameAr": {
                    "type": "string"
                  },
                  "Email": {
                    "type": "string",
                    "format": "email"
                  },
                  "WebsiteUrl": {
                    "type": "string"
                  },
                  "LogoName": {
                    "type": "string"
                  },
                  "LogoPath": {
                    "type": "string",
                    "format": "binary"
                  },
                  "PhoneNumber": {
                    "type": "string"
                  }
                }
              },
              "encoding": {
                "NameEn": {
                  "style": "form"
                },
                "NameAr": {
                  "style": "form"
                },
                "Email": {
                  "style": "form"
                },
                "WebsiteUrl": {
                  "style": "form"
                },
                "LogoName": {
                  "style": "form"
                },
                "LogoPath": {
                  "style": "form"
                },
                "PhoneNumber": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Account/setpassword": {
      "post": {
        "tags": [
          "Account"
        ],
        "requestBody": {
          "content": {
